# Root-level shared sample environment. Copy to .env and adjust as needed.

# Database. Leave unset to use a zero-setup local SQLite file (backend/app.db).
# For Postgres (via docker-compose), use:
# DATABASE_URL=postgresql+psycopg://interview:interview@localhost:5432/interview
DATABASE_URL=

# Comma-free JSON list is not required; pydantic-settings parses JSON for lists.
# CORS origins allowed to call the API (defaults cover the Vite dev server).
# CORS_ORIGINS=["http://localhost:5173"]

# OpenAI key used by the agent (backend/models.py).
OPENAI_API_KEY=

# Confluence credentials (only needed to (re)import guidelines).
# CONFLUENCE_URL=
# CONFLUENCE_USERNAME=
# CONFLUENCE_API_TOKEN=
